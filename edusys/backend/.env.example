# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=edusys

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# 服务配置
PORT=3000
NODE_ENV=development

# CORS 配置（生产环境填写，多个域名用逗号分隔）
# 示例: CORS_ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
CORS_ALLOWED_ORIGINS=

# Python 微服务地址（成绩导入功能）
PYTHON_API_URL=http://localhost:8000/api/v1